{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "lib": ["ES2021", "DOM"],
    "outDir": "./public/js",
    "rootDir": "./src/ts",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/ts/**/*"]
}
